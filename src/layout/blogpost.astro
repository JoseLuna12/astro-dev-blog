---
import { getLanguageLabel } from "../utils/languageUtils";
import {
  buildCategoryPath,
  buildLocalizedPostPath,
  getResponsiveImage,
  PostsTagsDefault,
} from "../utils/postUtils";
import { getLocale, siteConfig, toAbsoluteUrl } from "../utils/site";

type Props = {
  lang: "en" | "es";
  title: string;
  subtitle: string;
  categories: string[];
  blogId: string;
  languages: string[];
  icon?: string;
  accent: string;
  images: string[];
  thumbnails: string[];
};

const {
  title,
  lang,
  categories,
  subtitle,
  blogId,
  languages,
  icon,
  accent,
  images,
  thumbnails,
} = Astro.props;

const pageIcon = icon
  ? PostsTagsDefault.find((tag) => tag.value === icon)?.img ?? PostsTagsDefault[0].img
  : PostsTagsDefault[0].img;
const { src: socialImage } = getResponsiveImage([...thumbnails, ...images]);
const { src: blogImageSrc, srcset: imageSrcSet } = getResponsiveImage(images);
const safeSocialImage = socialImage || siteConfig.defaultSocialImage;
const baseUrl = Astro.site?.toString() ?? siteConfig.siteUrl;
const canonicalUrl = toAbsoluteUrl(buildLocalizedPostPath(lang, blogId), baseUrl);
const uniqueLanguages = [...new Set(languages)] as ("en" | "es")[];
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={pageIcon} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={subtitle} />
    <link rel="canonical" href={canonicalUrl} />
    {
      uniqueLanguages.map((language) => (
        <link
          rel="alternate"
          hreflang={language}
          href={toAbsoluteUrl(buildLocalizedPostPath(language, blogId), baseUrl)}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={toAbsoluteUrl(buildLocalizedPostPath("en", blogId), baseUrl)}
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={subtitle} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={safeSocialImage} />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:locale" content={getLocale(lang)} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={subtitle} />
    <meta name="twitter:image" content={safeSocialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image:alt" content={title} />
    <title>{title}</title>
  </head>
  <body class="bg-white text-zinc-950">
    <div class="w-full py-10">
      <a href={`/${lang}`}>
        <img
          class="m-auto h-[20px] w-[20px] transition ease-in-out hover:scale-125"
          src="/home.png"
          alt={lang === "es" ? "Volver al inicio" : "Back to home"}
        />
      </a>
    </div>
    <div class="w-full flex justify-center space-x-2 py-5">
      {
        uniqueLanguages.map((language, index) => {
          return (
            <div>
              <a
                href={buildLocalizedPostPath(language, blogId)}
                class:list={[{ "text-red-500": lang === language }]}
              >
                {getLanguageLabel(language)}
              </a>
              {index !== uniqueLanguages.length - 1 ? <span>|</span> : ""}
            </div>
          );
        })
      }
    </div>

    <div class="px-5 md:px-0">
      <h1 class="py-2 text-center text-4xl font-bold">{title}</h1>
      <h2 class="py-1 text-center text-xl">{subtitle}</h2>
    </div>
    <div class="flex justify-center space-x-2 px-5 pt-5 md:space-x-5 lg:space-x-7">
      {
        categories.map((category) => {
          return (
            <a href={buildCategoryPath(lang, category as never)}>
              <div class="rounded-full bg-slate-400 px-3 py-1 text-sm text-white">
                {category}
              </div>
            </a>
          );
        })
      }
    </div>
    <div class="flex w-full flex-col px-10 pt-10 md:px-10 lg:px-20">
      {
        blogImageSrc && (
          <div class="h-auto w-auto place-self-center">
            <img
              class="max-h-[520px] rounded-xl object-cover"
              sizes="(min-width: 1024px) 960px, 100vw"
              src={blogImageSrc}
              srcset={imageSrcSet || undefined}
              alt={title}
            />
          </div>
        )
      }
      <div class="flex justify-center px-0 pt-5 md:px-10 md:pt-10 lg:px-20 lg:pt-20">
        <article
          class={`prose w-full prose-zinc prose-img:rounded-xl prose-table:sm:table md:prose-xl lg:prose-xl`}
        >
          <slot name="blog" />
        </article>
      </div>
    </div>
  </body>
</html>

<style is:global define:vars={{ accent }}>
  .prose :where(a) {
    color: var(--accent) !important;
  }
</style>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;700&display=swap");

  * {
    font-family: "Poppins", sans-serif;
  }

  body {
    margin: 0;
  }

  .img-carousel-blog {
    display: flex;
    justify-content: space-around;
  }

  .img-carousel-blog p {
    flex: 1;
  }

  .img-carousel-blog-col {
    display: flex;
    flex-direction: column;
    justify-content: space-around;
  }

  .img-carousel-blog-col p {
    flex: 1;
  }

  @media only screen and (max-width: 600px) {
    .img-carousel-blog {
      display: flex;
      flex-direction: column;
    }
  }
</style>
