---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import Blogpost from "../../layout/blogpost.astro";
import type { SupportedLanguagesTypes } from "../../utils/languageUtils";
import { getBlogIdFromSlug } from "../../utils/postUtils";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

type Props = CollectionEntry<"blog">;

const post = Astro.props as Props;
const { slug, data } = post;
const { Content } = await post.render();
const blogId = getBlogIdFromSlug(slug);

const {
  categories,
  description,
  title,
  currentLanguage,
  languages,
  accent,
  images,
  thumbnails,
} = data;
const icon = categories[0] || "";
const lang = currentLanguage as SupportedLanguagesTypes;
---

<Blogpost
  accent={accent}
  icon={icon}
  languages={languages}
  categories={categories}
  blogId={blogId}
  lang={lang}
  subtitle={description}
  title={title}
  images={images ?? []}
  thumbnails={thumbnails ?? []}
>
  <Content slot="blog" />
</Blogpost>
