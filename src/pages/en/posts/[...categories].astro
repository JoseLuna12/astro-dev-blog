---
import PostsComponent from "../../../components/PostsComponent.astro";
import type { SupportedLanguagesTypes } from "../../../utils/languageUtils";
import {
  AllowedPostTags,
  isPostTag,
  type PostsTagsType,
} from "../../../utils/postUtils";
const lang: SupportedLanguagesTypes = "en";

export async function getStaticPaths() {
  return AllowedPostTags.map((p) => {
    return {
      params: { categories: p },
    };
  });
}

const routeCategory = Astro.params.categories ?? "All";
const filter: PostsTagsType = isPostTag(routeCategory) ? routeCategory : "All";
---

<PostsComponent currentCategory={filter} lang={lang} />
