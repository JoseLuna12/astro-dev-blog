---
import { getCollection } from "astro:content";
import MainLayout from "../layout/main.astro";
import Hero from "./hero.svelte";
import SmallPost from "./smallPost.svelte";
import Button from "./Button.svelte";
import type { SupportedLanguagesTypes } from "../utils/languageUtils";
import { getFeaturedPosts, getPostsByLang } from "../utils/postUtils";
import { siteConfig } from "../utils/site";

interface Props {
  lang: SupportedLanguagesTypes;
  more: string;
}

const { more, lang = "en" } = Astro.props;

const rawPosts = await getCollection("blog");
const posts = getPostsByLang(lang, rawPosts);
const featuredPosts = getFeaturedPosts(posts);

const pageContent = {
  en: {
    title: "Devlog",
    description: siteConfig.defaultDescriptions.en,
  },
  es: {
    title: "Devlog",
    description: siteConfig.defaultDescriptions.es,
  },
};
---

<MainLayout
  title={pageContent[lang].title}
  description={pageContent[lang].description}
  lang={lang}
  socialImage={siteConfig.defaultSocialImage}
>
  <Hero title={siteConfig.heroTitle} homeHref={`/${lang}`} slot="hero" />

  <div class="grid grid-cols-1 gap-24 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3">
    {
      featuredPosts.map((post) => {
        const { data, slug } = post;
        return (
          <SmallPost
            slug={slug}
            title={data.title}
            subtitle={data.description}
            categories={data.categories}
            thumbnails={data.thumbnails ?? []}
            lang={lang}
          />
        );
      })
    }
  </div>
  <div>
    <Button href={`/${lang}/posts/All`} buttonText={more} position="center" />
  </div>
</MainLayout>
