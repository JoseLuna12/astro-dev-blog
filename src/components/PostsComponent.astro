---
import { getCollection } from "astro:content";
import Main from "../layout/main.astro";
import type { SupportedLanguagesTypes } from "../utils/languageUtils";
import {
  AllowedPostTags,
  buildCategoryPath,
  buildPostPath,
  getResponsiveImage,
  getPostsByLang,
  isPostTag,
  sortPostsByDateDesc,
  type PostsTagsType,
} from "../utils/postUtils";
import Hero from "./hero.svelte";

interface Props {
  lang: SupportedLanguagesTypes;
  currentCategory: PostsTagsType;
}

const { lang = "en", currentCategory } = Astro.props;
const filter = isPostTag(currentCategory) ? currentCategory : "All";

const rawPosts = await getCollection("blog");
const posts = sortPostsByDateDesc(getPostsByLang(lang, rawPosts)).filter((post) =>
  filter === "All" ? true : post.data.categories.includes(filter)
);

const allDisplay = {
  en: "All",
  es: "Todos",
};

const pageTitles = {
  en: filter === "All" ? "All posts" : `${filter} posts`,
  es: filter === "All" ? "Todos los articulos" : `Articulos de ${filter}`,
};

const pageDescriptions = {
  en:
    filter === "All"
      ? "Browse every project note and article from the devlog."
      : `Browse ${filter} articles from the devlog.`,
  es:
    filter === "All"
      ? "Explora todos los articulos y notas de proyecto del devlog."
      : `Explora los articulos de ${filter} del devlog.`,
};
---

<Main
  title={pageTitles[lang]}
  description={pageDescriptions[lang]}
  lang={lang}
  urlSuffix={`posts/${filter}`}
>
  <Hero title="Devlog" homeHref={`/${lang}`} slot="hero" />
  <div
    slot="top-head"
    class="flex my-5 justify-start space-x-1 overflow-x-scroll px-3 py-5 sm:justify-start md:justify-center md:space-x-4 lg:justify-center"
  >
    {
      AllowedPostTags.map((tag) => {
        const categoriesCss =
          filter === tag
            ? "border-black bg-black text-white"
            : "border-black bg-white text-black";

        return (
          <a href={buildCategoryPath(lang, tag)}>
            <div
              class={`rounded-full border px-5 py-1 text-sm ${categoriesCss} transition ease-out duration-300 hover:scale-105`}
            >
              {tag === "All" ? allDisplay[lang] : tag}
            </div>
          </a>
        );
      })
    }
  </div>
  <div class="px-0 md:px-32 lg:px-36">
    {
      posts.length === 0 ? (
        <p class="px-4 py-10 text-lg text-zinc-600">
          {lang === "es"
            ? "No hay articulos en esta categoria todavia."
            : "There are no posts in this category yet."}
        </p>
      ) : (
        posts.map((post) => {
          const thumbnails = post.data.thumbnails ?? [];
          const { src: thumbnailSrc, srcset: thumbnailsSrcSet } = getResponsiveImage(
            thumbnails
          );
          const fallbackSrc = post.data.images?.[0] ?? "";

          return (
            <article class="flex w-full flex-col sm:flex-row md:flex-row lg:flex-row">
              <a href={buildPostPath(post.slug)} class="flex-1">
                <img
                  srcset={thumbnailsSrcSet || undefined}
                  sizes="(min-width: 768px) 50vw, 100vw"
                  class="h-full w-full rounded-xl object-cover"
                  src={thumbnailSrc || fallbackSrc}
                  alt={post.data.title}
                />
              </a>
              <div class="flex-1">
                <div class="px-4 py-10">
                  <a href={buildPostPath(post.slug)} class="group">
                    <h2 class="font-bold transition ease-out duration-300 group-hover:bg-gradient-to-r group-hover:from-pink-500 group-hover:to-violet-500 group-hover:bg-clip-text group-hover:text-transparent">
                      {post.data.title}
                    </h2>
                    <p>{post.data.description}</p>
                  </a>
                  <div class="flex flex-wrap gap-2 py-5">
                    {post.data.categories.map((category) => {
                      return (
                        <a href={buildCategoryPath(lang, category)}>
                          <div class="rounded-full bg-slate-400 px-3 py-1 text-sm text-white transition ease-out duration-300 hover:scale-105">
                            {category}
                          </div>
                        </a>
                      );
                    })}
                  </div>
                </div>
              </div>
            </article>
          );
        })
      )
    }
  </div>
</Main>
